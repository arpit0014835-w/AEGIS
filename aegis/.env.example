# ──────────────────────────────────────────────
# AEGIS — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# ─── Application ───
APP_NAME=aegis
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ─── Backend ───
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_NAME=aegis:scan_jobs
REDIS_RESULT_TTL=3600

# ─── Azure OpenAI (optional — for semantic vulnerability analysis) ───
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ─── Azure AI Content Safety (optional — for jailbreak detection) ───
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_API_KEY=

# ─── Scanning ───
SEMGREP_RULES_DIR=rules/semgrep
UPLOAD_DIR=./tmp/uploads
CLONE_DIR=./tmp/repos
MAX_REPO_SIZE_MB=500
SCAN_TIMEOUT_SECONDS=600

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
