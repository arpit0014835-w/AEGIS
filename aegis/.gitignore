# ──────────────────────────────────────────────
# AEGIS — .gitignore
# ──────────────────────────────────────────────

# ─── Python ───
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.python-version

# ─── Node.js ───
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── IDE ───
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── OS ───
.DS_Store
Thumbs.db
Desktop.ini

# ─── Environment ───
.env
.env.local
.env.*.local

# ─── Docker ───
docker-compose.override.yml

# ─── Coverage & Testing ───
htmlcov/
.coverage
.coverage.*
.pytest_cache/
coverage/
.nyc_output/

# ─── Temp / Uploads ───
tmp/
temp/
uploads/
*.tmp

# ─── Logs ───
logs/
*.log
